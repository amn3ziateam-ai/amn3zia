<?xml version="1.0" encoding="utf-8"?>
<!-- Privacy: explicitly exclude all app data from cloud backup / device transfer -->
<data-extraction-rules>
    <cloud-backup disableIfNoEncryptionCapability="true">
        <exclude domain="root" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
    </device-transfer>
</data-extraction-rules>
